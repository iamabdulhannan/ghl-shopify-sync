# Server
PORT=3000
LOG_LEVEL=info

# GoHighLevel — get from Settings → Business Profile → API Keys
GHL_API_KEY=your-ghl-location-api-key
GHL_LOCATION_ID=your-ghl-location-id

# Shopify webhook signing secret — shown once when you create the webhook
SHOPIFY_WEBHOOK_SECRET=your-shopify-webhook-shared-secret
