# Shopify Partner Dashboard creates these — see README setup steps
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SCOPES=read_orders,read_customers,read_products
SHOPIFY_APP_URL=

# Database (Prisma) — sqlite for dev, Postgres for prod
DATABASE_URL="file:./prisma/dev.sqlite"

# Optional encryption key for storing merchants' GHL keys at rest
# Generate with: openssl rand -hex 32
APP_ENCRYPTION_KEY=

# Logging
LOG_LEVEL=info
