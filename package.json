    "@remix-run/serve": "^2.13.1",
    "@shopify/app-bridge-react": "^4.1.6",
    "@shopify/polaris": "^13.9.0",
    "@shopify/shopify-app-remix": "^3.5.0",
    "@shopify/shopify-app-session-storage-prisma": "^5.2.0",
    "axios": "^1.7.7",
    "isbot": "^5.1.17",
    "pino": "^9.5.0",
    "prisma": "^5.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite-tsconfig-paths": "^5.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@remix-run/route-config": "^2.13.1",
    "@shopify/api-codegen-preset": "^1.1.4",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
